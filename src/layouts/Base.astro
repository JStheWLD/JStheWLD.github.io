---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  nav?: 'overlay' | 'solid' | 'none';
}
const {
  title,
  description = "The house Jonathan Sexton's work lives in: essays, songs, and a book in progress, all chasing one question, how we stay human while the world speeds up.",
  nav = 'solid',
} = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" href="/assets/storm-door/favicon-512.png" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,opsz,wght@0,6..96,400;0,6..96,500;1,6..96,400;1,6..96,500&family=Libre+Baskerville:ital@0;1&family=Reenie+Beanie&display=swap" rel="stylesheet" />
</head>
<body>
  <!-- ink / torn-paper roughening filters, referenced by hand-drawn marks and collage scraps -->
  <svg width="0" height="0" style="position:absolute" aria-hidden="true" focusable="false">
    <defs>
      <filter id="ink" x="-20%" y="-40%" width="140%" height="180%">
        <feTurbulence type="fractalNoise" baseFrequency="0.028" numOctaves="2" seed="7" result="n" />
        <feDisplacementMap in="SourceGraphic" in2="n" scale="5.5" xChannelSelector="R" yChannelSelector="G" />
      </filter>
      <filter id="torn" x="-8%" y="-8%" width="116%" height="116%">
        <feTurbulence type="fractalNoise" baseFrequency="0.014 0.02" numOctaves="4" seed="3" result="n" />
        <feDisplacementMap in="SourceGraphic" in2="n" scale="16" />
      </filter>
    </defs>
  </svg>
  {nav !== 'none' && <Nav variant={nav === 'overlay' ? 'overlay' : 'solid'} />}
  <slot />
  <Footer />
  <script>
    document.documentElement.classList.add('js');
    const reveals = document.querySelectorAll('.reveal');
    const showAll = () => reveals.forEach((el) => el.classList.add('in'));
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
      }
    }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
    reveals.forEach((el) => io.observe(el));
    // Failsafe: content must never stay hidden if IO doesn't fire
    // (hidden tab, headless render, no scroll). Reveal everything after a beat.
    setTimeout(showAll, 1400);
    document.addEventListener('visibilitychange', () => { if (document.hidden) showAll(); });
  </script>
</body>
</html>
