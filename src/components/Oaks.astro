---
// Southern live oaks with Spanish moss — hand-drawn line art.
// Low, wide, spreading crowns and long moss curtains (the live-oak habit),
// roughened by the #ink filter. Strokes use currentColor to theme per section.
interface Props { class?: string; }
const { class: cls = '' } = Astro.props;

const r = (n: number) => Math.round(n * 100) / 100;
// a moss curtain: a longer wavy strand hanging from (mx,my)
const moss = (mx: number, my: number, len: number) =>
  `M ${mx} ${my} q 4 ${r(len * 0.3)} 0 ${r(len * 0.5)} t -3 ${r(len * 0.5)} t 3 ${r(len * 0.5)}`;

// One live oak: short thick trunk, heavy low limbs that spread wide and dip,
// a broad low canopy, and moss hanging in curtains. Local origin at the base.
const treePaths = [
  // trunk (two lines for weight)
  'M-7 0 C -5 -22 -9 -40 -4 -52', 'M7 0 C 8 -22 3 -40 5 -52',
  // heavy limbs, spreading wide, the outer two dipping toward the ground
  'M-4 -50 C -44 -58 -96 -54 -146 -34 C -172 -24 -184 -12 -188 2',
  'M5 -50 C 46 -60 100 -56 152 -34 C 180 -22 192 -8 196 4',
  'M-2 -52 C -34 -76 -74 -90 -110 -96',
  'M4 -52 C 30 -78 72 -92 110 -96',
  'M1 -54 C -1 -84 3 -110 6 -128',
  // broad low canopy (wider than tall), drawn as a loose scribbled mass
  'M-176 -34 C -202 -74 -150 -116 -104 -106 C -88 -128 -34 -132 -16 -110 C 8 -132 66 -130 86 -102 C 130 -118 178 -84 160 -46 C 184 -22 150 2 108 -8',
  'M108 -8 C 44 8 -70 8 -128 -6 C -166 -16 -190 -18 -176 -34',
  // a few interior foliage strokes for texture
  'M-120 -70 c 22 -14 54 -16 78 -6', 'M-40 -96 c 30 -12 66 -10 92 4', 'M40 -84 c 30 -6 62 2 84 16',
  // spanish moss curtains, varied length, hung along the canopy underside
  moss(-150, -30, 70), moss(-120, -48, 96), moss(-84, -22, 60),
  moss(-40, -60, 110), moss(6, -30, 84), moss(52, -58, 100),
  moss(104, -34, 72), moss(148, -18, 58),
];

const instances = [
  { x: 300, s: 1.45 },
  { x: 730, s: 1.12 },
];
---
<svg class={`oaks ${cls}`} viewBox="0 0 1000 340" fill="none" role="img"
  aria-label="Southern live oaks draped in Spanish moss, drawn by hand" preserveAspectRatio="xMidYMax meet">
  <g transform="translate(0 322)">
    {instances.map((t) => (
      <g transform={`translate(${t.x} 0) scale(${t.s})`}>
        {treePaths.map((d) => <path d={d} />)}
      </g>
    ))}
  </g>
  <path d="M36 324 C 260 318, 520 328, 764 322 S 962 324, 970 322" />
</svg>

<style>
  .oaks{display:block; width:100%; height:auto; color:var(--ink)}
  .oaks path{stroke:currentColor; stroke-width:1.4; stroke-linecap:round; stroke-linejoin:round; fill:none; filter:url(#ink)}
</style>
